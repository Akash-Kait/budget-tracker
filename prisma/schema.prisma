generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FinancialProfile {
  id                 Int      @id @default(1)
  reserveTarget      Float    @default(0)
  reserveCurrent     Float    @default(0)
  monthlyIncome      Float    @default(0)
  monthlyExpenses    Float    @default(0)
  monthlyInvestments Float    @default(0)
  updatedAt          DateTime @updatedAt
}

model WealthAsset {
  id             String    @id @default(cuid())
  name           String
  type           String // MUTUAL_FUND | STOCK | OTHER
  ticker         String?
  quantity       Float?
  pricePerUnit   Float?
  value          Float? // manual fallback when units/price don't apply
  lastPrice      Float? // last fetched/entered unit price (market-data headroom)
  priceUpdatedAt DateTime? // when pricePerUnit was last set
  priceSource    String? // MANUAL | API
  priceStatus    String? // OK | NOT_FOUND (scheme code didn't resolve on last refresh); null = n/a
  tickerName     String? // provider-resolved name for `ticker` (echoed back so a wrong code shows); null = n/a
  source         String? // CAS | MANUAL (null = legacy/manual); scopes what CAS reconciliation may touch
  importKey      String? // stable CAS reconciliation key (AMFI code, else folio|scheme) — idempotency backbone
  casStatus      String? // CURRENT | ABSENT ("not in latest CAS"); null = not CAS-sourced
  costBasis      Float? // total amount invested (₹); null = unknown
  purchaseDate   DateTime? // optional; display + future XIRR headroom
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([importKey])
  // Source-scoped uniqueness: a given importer (CAS folio|amfi, eCAS boId|isin) maps to at most ONE
  // row — the DB backstop against a duplicate-key double-create. Source-scoped so CAS and eCAS key
  // spaces stay independent; nullable members (manual rows = null/null) may repeat freely.
  @@unique([source, importKey])
}

model PlanItem {
  id                String               @id @default(cuid())
  type              String // COMMITMENT | GOAL | EXPERIENCE | WISHLIST
  title             String
  amount            Float                @default(0)
  priority          Int                  @default(3)
  dueDate           DateTime?
  status            String? // PLANNED | FUNDED | COMPLETED (any type)
  notes             String?
  coolingPeriodDays Int                  @default(30)
  dateAdded         DateTime             @default(now())
  purchased         Boolean              @default(false)
  rank              Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  fundings          FundingTransaction[]
}

model FundingTransaction {
  id        String   @id @default(cuid())
  itemId    String
  item      PlanItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  amount    Float
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([itemId])
}
