# Copy to .env and adjust. .env is gitignored.

# SQLite database location (Prisma).
DATABASE_URL="file:./dev.db"

# Live price provider for the Wealth page. Unset (or any other value) = manual prices only
# (the default — no external calls). Set to `amfi` to fetch end-of-day mutual-fund NAVs from
# AMFI's published feed. AMFI covers mutual funds only; stocks/other stay manual.
# MARKET_DATA_PROVIDER=amfi

# Live STOCK price provider (independent of the MF provider above, so the two fail separately).
# Unset (or any other value) = manual; stocks keep their eCAS statement-date price. Set to `nse`
# to fetch NSE end-of-day closes via the Python sidecar (scripts/nse_quote.py). Requires Python 3 +
# nselib installed: `pip install -r scripts/requirements.txt` (into scripts/.venv). Restart after setting.
# EQUITY_DATA_PROVIDER=nse
